APP_NAME=stock_ai_assistant
APP_ENV=local
DATABASE_URL=sqlite:///data/stock_ai_assistant.db
TIMEZONE=Asia/Shanghai

# Email report schedule. Multiple HH:MM values are supported.
EMAIL_ENABLED=true
EMAIL_SEND_TIMES=08:50,12:50
EMAIL_TIMEZONE=Asia/Shanghai

# SMTP config. QQ Mail requires an SMTP authorization code, not the login password.
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USERNAME=your_email@qq.com
EMAIL_PASSWORD=your_smtp_auth_code
EMAIL_FROM=your_email@qq.com
EMAIL_TO=your_receive_email@qq.com

# The app also accepts these legacy names:
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
# SENDER_EMAIL=your_email@qq.com
# SENDER_PASS=your_smtp_auth_code
# RECEIVER_EMAIL=your_receive_email@qq.com

AI_ENABLED=true
AI_PROVIDER=deepseek
AI_API_KEY=your_deepseek_api_key
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com/v1

STOP_LOSS_THRESHOLD=-0.08
TAKE_PROFIT_THRESHOLD=0.20
MAX_SUGGESTED_POSITION=0.30
ENABLE_NEWS_ANALYSIS=true
ENABLE_AI_SUMMARY=true
ENABLE_SIGNAL_TRACKING=true
