APP_NAME=stock_ai_assistant
APP_ENV=local
DATABASE_URL=sqlite:///data/stock_ai_assistant.db
TIMEZONE=Asia/Shanghai

EMAIL_ENABLED=true
EMAIL_SEND_TIMES=08:50,14:20
EMAIL_TIMEZONE=Asia/Shanghai
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USERNAME=your_email@qq.com
EMAIL_PASSWORD=your_smtp_auth_code
EMAIL_FROM=your_email@qq.com
EMAIL_TO=your_receive_email@qq.com

AI_ENABLED=false
AI_PROVIDER=deepseek
AI_API_KEY=your_api_key
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com/v1

STOP_LOSS_THRESHOLD=-0.08
TAKE_PROFIT_THRESHOLD=0.20
MAX_SUGGESTED_POSITION=0.30
ENABLE_NEWS_ANALYSIS=true
ENABLE_AI_SUMMARY=true
ENABLE_SIGNAL_TRACKING=true
